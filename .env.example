# Redis
REDIS_URL=redis://localhost:6379

# PostgreSQL
DATABASE_URL=postgresql://iracing:iracing@localhost:5432/iracing_engineer

# LLM
LLM_MODE=frontier                        # frontier | local
ANTHROPIC_API_KEY=
LLM_BASE_URL=http://localhost:11434/v1   # for local mode
LLM_MODEL=claude-sonnet-4-6

# Speech services (homelab)
SPEACHES_URL=http://speaches:8000
CHATTERBOX_URL=http://chatterbox:8001

# OBS WebSocket
OBS_WS_URL=ws://localhost:4455
OBS_WS_PASSWORD=

# Discord
DISCORD_WEBHOOK_URL=

# Auth (Authentik)
AUTHENTIK_ISSUER=
AUTHENTIK_CLIENT_ID=
AUTHENTIK_CLIENT_SECRET=

# OpenTelemetry
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318
OTEL_SERVICE_NAME=hub-server

# Hub
HUB_PORT=3000
HUB_SECRET=change-me
